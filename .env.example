# 桑芽记后端环境配置

# 数据库
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sangyaji?schema=public"

# JWT
JWT_SECRET="sangyaji-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# 微信小程序
WECHAT_APPID=""
WECHAT_SECRET=""

# 阿里云OSS
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET="sangyaji-media"
OSS_REGION="oss-cn-hangzhou"
OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"

# AI - 通义千问
QWEN_API_KEY=""
QWEN_MODEL="qwen-max"

# AI - OpenAI (备选)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# 推送 - 极光
JPUSH_APP_KEY=""
JPUSH_MASTER_SECRET=""

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# 服务端口
PORT=3000
