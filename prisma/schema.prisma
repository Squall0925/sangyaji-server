// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// 用户与认证
// ============================================================

model User {
  id             String    @id @default(cuid())
  phone          String?   @unique
  wechatOpenid   String?   @unique
  wechatUnionid  String?
  nickname       String    @default("蚕友")
  avatarUrl      String?
  ageMode        String    @default("standard") // junior | standard
  isChildMode    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  projects       Project[]
  subscriptions  Subscription[]
}

// ============================================================
// 养蚕项目
// ============================================================

model Project {
  id                    String    @id @default(cuid())
  userId                String
  name                  String    @default("我的蚕宝宝")
  silkwormCount         Int       @default(5)
  startDate             DateTime
  currentStageId        String    @default("egg")
  currentStageStartedAt DateTime  @default(now())
  isAutoStage           Boolean   @default(true)
  status                String    @default("active") // active | completed | archived
  settings              String    @default("{\"morningReminderTime\":\"08:00\",\"eveningReminderTime\":\"19:00\",\"enablePush\":true}")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageLogs  StageLog[]
  records    Record[]
  taskLogs   TaskLog[]
  diaryBooks DiaryBook[]
  badges     Badge[]
  reminders  ReminderRule[]

  @@index([userId])
}

// ============================================================
// 阶段日志
// ============================================================

model StageLog {
  id              String    @id @default(cuid())
  projectId       String
  stageId         String
  startedAt       DateTime
  endedAt         DateTime?
  isManualAdjust  Boolean   @default(false)
  note            String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, startedAt])
}

// ============================================================
// 记录
// ============================================================

model Record {
  id             String   @id @default(cuid())
  projectId      String
  date           DateTime
  stageId        String
  dayInStage     Int
  authorType     String   @default("parent") // parent | child
  authorName     String?
  textContent    String?
  tags           String   @default("[]")
  weather        String?
  temperature    Float?
  mood           String?  // happy | neutral | sad
  linkedTaskIds  String   @default("[]")
  createdAt      DateTime @default(now())

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mediaItems MediaItem[]

  @@index([projectId, date])
}

// ============================================================
// 媒体项
// ============================================================

model MediaItem {
  id           String   @id @default(cuid())
  recordId     String
  type         String   // image | video
  url          String
  thumbnailUrl String?
  duration     Float?   // 视频时长(秒)
  fileSize     Int?
  width        Int?
  height       Int?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  record Record @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId, sortOrder])
}

// ============================================================
// 任务模板（预置数据）
// ============================================================

model TaskTemplate {
  id                   String   @id @default(cuid())
  stageId              String
  title                String
  titleJunior          String
  description          String
  descriptionJunior    String
  taskType             String   // feeding | cleaning | observation | measurement | milestone | preparation
  suggestedTime        String   // morning | afternoon | evening | anytime
  requiredRecordType   String   @default("none") // photo | video | text | measurement | none
  isDaily              Boolean  @default(true)
  dayOffset            Int?
  priority             Int      @default(2)
  isWarning            Boolean  @default(false)
  sortOrder            Int      @default(0)

  taskLogs TaskLog[]

  @@index([stageId])
}

// ============================================================
// 任务完成日志
// ============================================================

model TaskLog {
  id             String   @id @default(cuid())
  projectId      String
  taskTemplateId String?
  templateId     String?  // 兼容前端模板ID
  date           DateTime
  completedAt    DateTime @default(now())
  completedBy    String   @default("parent") // parent | child — 纯字符串，不是FK

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskTemplate TaskTemplate? @relation(fields: [taskTemplateId], references: [id])

  @@index([projectId, date])
}

// ============================================================
// AI日记本
// ============================================================

model DiaryBook {
  id               String    @id @default(cuid())
  projectId        String
  status           String    @default("generating") // generating | completed | failed
  contentJson      String?
  coverImageUrl    String?
  totalWords       Int?
  generatedAt      DateTime?
  generationConfig String?
  regenerateCount  Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================================
// 提醒规则
// ============================================================

model ReminderRule {
  id        String   @id @default(cuid())
  projectId String
  type      String   // morning_feed | noon_observe | evening_check | stage_change | abnormal
  time      String?  // HH:mm
  isEnabled Boolean  @default(true)
  platform  String   @default("app") // app | miniprogram

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================================
// 徽章
// ============================================================

model Badge {
  id        String   @id @default(cuid())
  projectId String
  type      String
  earnedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================================
// 订阅
// ============================================================

model Subscription {
  id             String    @id @default(cuid())
  userId         String
  plan           String    @default("free") // free | mulberry | silkworm | school
  startedAt      DateTime
  expiresAt      DateTime?
  paymentMethod  String?
  transactionId  String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
